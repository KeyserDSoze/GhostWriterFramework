# Google OAuth client ID (required for Google Drive sign-in)
# Create at https://console.cloud.google.com -> APIs & Services -> Credentials
# Authorized JavaScript origins: https://narrarium.net, http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Microsoft Entra ID app registration client ID (required for OneDrive sign-in)
# Redirect URI: https://narrarium.net/ and http://localhost:5173/
VITE_MICROSOFT_CLIENT_ID=your-entra-application-client-id

# Override the base path for GitHub Pages project deployments.
# Use / for narrarium.net custom domain deployments.
# SITE_BASE=/GhostWriterFramework/
