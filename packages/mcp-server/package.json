{
  "name": "narrarium-mcp-server",
  "version": "0.1.49",
  "type": "module",
  "description": "Local MCP server for Narrarium book repositories.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KeyserDSoze/GhostWriterFramework",
    "directory": "packages/mcp-server"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "narrarium-mcp": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./public-http-server": {
      "types": "./dist/public-http-server.d.ts",
      "import": "./dist/public-http-server.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "narrarium",
    "mcp",
    "model-context-protocol",
    "books",
    "writing"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "narrarium": "^0.1.27",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
