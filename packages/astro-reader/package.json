{
  "name": "narrarium-astro-reader",
  "version": "0.1.37",
  "type": "module",
  "description": "Astro reader and scaffolding CLI for Narrarium book repositories.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KeyserDSoze/GhostWriterFramework",
    "directory": "packages/astro-reader"
  },
  "bin": {
    "narrarium-reader-init": "cli-dist/cli.js"
  },
  "exports": {
    "./scaffold": {
      "types": "./cli-dist/scaffold.d.ts",
      "import": "./cli-dist/scaffold.js",
      "require": "./cli-dist/scaffold.js",
      "default": "./cli-dist/scaffold.js"
    }
  },
  "files": [
    "cli-dist",
    "scripts",
    "src",
    "astro.config.mjs",
    "tsconfig.json"
  ],
  "keywords": [
    "narrarium",
    "astro",
    "books",
    "reader",
    "markdown"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:cli": "tsc -p tsconfig.cli.json",
    "export:epub": "node ./scripts/export-epub.mjs",
    "doctor": "node ./scripts/doctor.mjs",
    "dev": "node ./scripts/dev.mjs",
    "build": "npm run build:cli && npm run export:epub && astro build",
    "preview": "astro preview",
    "test": "npm run build:cli && node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "narrarium": "^0.1.27",
    "astro": "^5.14.1",
    "chokidar": "^4.0.3",
    "marked": "^16.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
