---
import { marked } from "marked";
import path from "node:path";
import { listChapters, pathExists } from "narrarium";
import AssetFigure from "../../components/AssetFigure.astro";
import ChapterPager from "../../components/ChapterPager.astro";
import LinkedValue from "../../components/LinkedValue.astro";
import MetadataSection from "../../components/MetadataSection.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadAssetFigure } from "../../lib/assets";
import { loadRelatedCanonLinks, loadStoryMentionLinks } from "../../lib/canon";
import { getBookRoot, loadChapterPageData } from "../../lib/book";

export async function getStaticPaths() {
  const root = getBookRoot();
  const ready = await pathExists(path.join(root, "book.md"));
  if (!ready) return [];

  const chapters = await listChapters(root);
  return chapters.map((chapter) => ({
    params: { chapter: chapter.slug },
    props: { chapterSlug: chapter.slug },
  }));
}

const { chapterSlug } = Astro.props;
const chapter = await loadChapterPageData(chapterSlug);
const allChapters = await listChapters(getBookRoot());
const currentIndex = allChapters.findIndex((entry) => entry.slug === chapterSlug);
const previousChapter = currentIndex > 0 ? allChapters[currentIndex - 1] : null;
const nextChapter = currentIndex >= 0 && currentIndex < allChapters.length - 1 ? allChapters[currentIndex + 1] : null;
const chapterHtml = await marked.parse(chapter.body);
const chapterMetaEntries: Array<[string, unknown]> = [
  ["Point of view", chapter.metadata.pov] as [string, unknown],
  ["Timeline", chapter.metadata.timeline_ref] as [string, unknown],
  ["Tags", chapter.metadata.tags] as [string, unknown],
].filter(([, value]) => value !== undefined && value !== null && (!Array.isArray(value) || value.length > 0));
const chapterId = String(chapter.metadata.id);
const chapterRelatedLinks = await loadRelatedCanonLinks(chapterId, [chapter.metadata.pov, chapter.metadata.timeline_ref]);
const chapterStoryLinks = await loadStoryMentionLinks(chapterId, chapter.metadata.number);
const chapterFigure = await loadAssetFigure(String(chapter.metadata.id), chapter.metadata.title);
const renderedParagraphs = await Promise.all(
  chapter.paragraphs.map(async (paragraph) => ({
    ...paragraph,
    anchorId: `scene-${path.basename(paragraph.path, ".md")}`,
    figure: await loadAssetFigure(String(paragraph.metadata.id), paragraph.metadata.title),
    html: await marked.parse(paragraph.body),
  })),
);
---

<BaseLayout
  title={chapter.metadata.title}
  description={chapter.metadata.summary}
  activeSection="chapters"
  currentChapterNumber={chapter.metadata.number}
>
  <section class="hero focus-hidden">
    <a class="chapter-back-link" href="./#chapters">Back to chapters</a>
    <p class="eyebrow">Chapter {String(chapter.metadata.number).padStart(3, "0")}</p>
    <h1>{chapter.metadata.title}</h1>
    {chapter.metadata.summary && <p class="lede">{chapter.metadata.summary}</p>}
    <div class="chip-row chapter-actions">
      <button type="button" class="chip is-action" data-bookmark-toggle>Save bookmark</button>
      <button type="button" class="chip is-action" data-tts-trigger="chapter" hidden>Read aloud</button>
      <button type="button" class="chip is-action" data-reader-focus-toggle>Full read</button>
    </div>
  </section>

  <div class="focus-hidden">
    <ChapterPager currentSlug={chapterSlug} chapters={allChapters} />
  </div>

  <section class="section chapter-reading-frame">
    <div class="chapter-focus-banner focus-hidden">
      <p class="eyebrow">Full read</p>
      <h2>{chapter.metadata.title}</h2>
      <p class="chapter-meta" data-reader-current-scene>Chapter opening</p>
    </div>

    {chapter.body && (
      <article
        class="scene prose"
        id="chapter-opening"
        data-reader-scene
        data-reader-scene-label="Chapter opening"
        data-reader-marker-article
        data-reader-marker-scope="chapter-intro"
        data-tts-root="chapter-intro"
        data-tts-label="Chapter opening"
        set:html={chapterHtml}
      />
    )}

    {chapterFigure && <AssetFigure figure={chapterFigure} className="scene-media focus-hidden" />}

    {renderedParagraphs.length > 0 && (
      <section class="section focus-hidden">
        <div class="card chapter-outline">
          <div class="chapter-outline__header">
            <h2>Scenes</h2>
            <div class="chapter-meta">{renderedParagraphs.length} total</div>
          </div>
          <div class="chapter-outline__list">
            {renderedParagraphs.map((paragraph) => (
              <a class="chapter-outline__item" href={`#${paragraph.anchorId}`}>
                <span class="chapter-outline__index">{String(paragraph.metadata.number).padStart(3, "0")}</span>
                <span>
                  <span class="chapter-outline__item-title">{paragraph.metadata.title}</span>
                  {paragraph.metadata.summary && <span class="chapter-outline__item-summary">{paragraph.metadata.summary}</span>}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section">
      {!chapter.body && <h2 class="focus-hidden">Scenes</h2>}
      <div class="scene-stack">
        {renderedParagraphs.length > 0 ? (
          renderedParagraphs.map((paragraph) => (
            <article
              class="scene"
              id={paragraph.anchorId}
              data-reader-scene
              data-reader-scene-label={`Scene ${String(paragraph.metadata.number).padStart(3, "0")} - ${paragraph.metadata.title}`}
              data-reader-marker-article
              data-reader-marker-scope={paragraph.anchorId}
            >
              <div class="scene-header">
                <div>
                  <div class="chapter-number">Scene {String(paragraph.metadata.number).padStart(3, "0")}</div>
                  <h3>{paragraph.metadata.title}</h3>
                </div>
                <div class="scene-tools">
                  <button
                    type="button"
                    class="chip is-action scene-marker"
                    data-reader-marker-set
                    data-reader-marker-scope={paragraph.anchorId}
                    data-reader-marker-label={`Scene ${String(paragraph.metadata.number).padStart(3, "0")} - ${paragraph.metadata.title}`}
                  >
                    Mark voice start
                  </button>
                  <button type="button" class="chip is-action" data-tts-trigger={paragraph.anchorId} hidden>Read aloud</button>
                </div>
              </div>

              {paragraph.metadata.summary && <p class="chapter-meta focus-hidden">{paragraph.metadata.summary}</p>}
              {paragraph.metadata.viewpoint && (
                <p class="chapter-meta focus-hidden">
                  Viewpoint: <LinkedValue value={paragraph.metadata.viewpoint} />
                </p>
              )}

              <div class="prose" data-tts-root={paragraph.anchorId} data-tts-label={paragraph.metadata.title} set:html={paragraph.html} />
              {paragraph.figure && <AssetFigure figure={paragraph.figure} className="scene-media focus-hidden" />}
            </article>
          ))
        ) : (
          <div class="empty">No paragraph files exist for this chapter yet.</div>
        )}
      </div>
    </section>
  </section>

  {chapterMetaEntries.length > 0 && (
    <section class="section focus-hidden">
      <MetadataSection entries={chapterMetaEntries} heading="Details" />
    </section>
  )}

  {chapterRelatedLinks.length > 0 && (
    <section class="section focus-hidden">
      <RelatedLinks links={chapterRelatedLinks} heading="Related" />
    </section>
  )}

  {chapterStoryLinks.length > 0 && (
    <section class="section focus-hidden">
      <RelatedLinks links={chapterStoryLinks} heading="Later mentions" />
    </section>
  )}

  <div class="focus-hidden">
    <ChapterPager currentSlug={chapterSlug} chapters={allChapters} />
  </div>

  <aside class="focus-rail" aria-label="Full read controls">
    <div class="focus-rail__meta">
      <div>
        <p class="eyebrow">Full read</p>
        <div class="focus-rail__title">{chapter.metadata.title}</div>
      </div>
    </div>
    <div class="focus-rail__controls">
      <a class:list={["focus-rail__link", !previousChapter && "is-disabled"]} href={previousChapter ? `chapters/${previousChapter.slug}/` : undefined} aria-disabled={!previousChapter}>Previous</a>
      <label class="focus-rail__jump">
        <span class="sr-only">Jump to chapter</span>
        <select data-reader-focus-jump aria-label="Jump to chapter">
          {allChapters.map((entry) => (
            <option value={entry.slug} selected={entry.slug === chapterSlug}>
              {`Chapter ${String(entry.metadata.number).padStart(3, "0")} - ${entry.metadata.title}`}
            </option>
          ))}
        </select>
      </label>
      <a class:list={["focus-rail__link", !nextChapter && "is-disabled"]} href={nextChapter ? `chapters/${nextChapter.slug}/` : undefined} aria-disabled={!nextChapter}>Next</a>
      <button type="button" class="focus-rail__button" data-reader-focus-toggle>Exit</button>
    </div>
  </aside>

  <div class="focus-hint" data-reader-focus-hint aria-hidden="true">
    Move the mouse, tap, or press a key to show controls.
  </div>

  <script is:inline>
    (() => {
      const focusModeKey = "narrarium-reader-focus-mode";
      const voiceMarkerKey = "narrarium-reader-voice-marker";
      const focusRailHideDelayMs = 1800;
      const focusHintHideDelayMs = 2600;
      const root = document.body;
      const chapterPath = window.location.pathname;
      const chapterSegments = chapterPath.split("/").filter(Boolean);
      const currentChapterSlug = chapterSegments[chapterSegments.length - 1] || "";
      const fullscreenTarget = document.documentElement;
      const toggleButtons = [...document.querySelectorAll("[data-reader-focus-toggle]")];
      const markerButtons = [...document.querySelectorAll("[data-reader-marker-set]")];
      const chapterJumpSelect = document.querySelector("[data-reader-focus-jump]");
      const focusRail = document.querySelector(".focus-rail");
      const focusHint = document.querySelector("[data-reader-focus-hint]");
      const currentSceneLabels = [...document.querySelectorAll("[data-reader-current-scene]")];
      const sceneElements = [...document.querySelectorAll("[data-reader-scene]")];
      let focusRailHideTimer = null;
      let focusHintHideTimer = null;
      let railPointerInside = false;
      let focusHintShownForSession = false;

      applyFocusMode(readStorage(focusModeKey) === "true", false, { allowFullscreenRequest: false });
      updateMarkerUi(readMarker());
      updateActiveScene();

      window.addEventListener("scroll", scheduleSceneRefresh, { passive: true });
      window.addEventListener("resize", scheduleSceneRefresh);
      document.addEventListener("pointermove", handleFocusRailWake, { passive: true });
      document.addEventListener("touchstart", handleFocusRailWake, { passive: true });
      document.addEventListener("fullscreenchange", handleFullscreenChange);

      focusRail?.addEventListener("pointerenter", () => {
        railPointerInside = true;
        showFocusRail();
      });
      focusRail?.addEventListener("pointerleave", () => {
        railPointerInside = false;
        scheduleFocusRailHide();
      });
      focusRail?.addEventListener("focusin", () => {
        showFocusRail();
      });
      focusRail?.addEventListener("focusout", () => {
        window.requestAnimationFrame(() => {
          scheduleFocusRailHide();
        });
      });

      toggleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          applyFocusMode(!root.classList.contains("is-focus-mode"), true, { allowFullscreenRequest: true });
        });
      });

      markerButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const marker = {
            path: chapterPath,
            scopeId: button.dataset.readerMarkerScope || "chapter",
            label: button.dataset.readerMarkerLabel || "Marked scene",
          };
          writeStorage(voiceMarkerKey, JSON.stringify(marker));
          updateMarkerUi(marker);
        });
      });

      chapterJumpSelect?.addEventListener("change", () => {
        const nextSlug = chapterJumpSelect.value;
        if (!nextSlug || nextSlug === currentChapterSlug) {
          return;
        }

        window.location.href = `chapters/${nextSlug}/`;
      });

      document.addEventListener("keydown", (event) => {
        if (isEditable(document.activeElement)) {
          return;
        }

        if (event.key === "Escape" && root.classList.contains("is-focus-mode")) {
          applyFocusMode(false, true, { allowFullscreenRequest: true });
          return;
        }

        if (!event.metaKey && !event.ctrlKey && !event.altKey && event.key.toLowerCase() === "f") {
          event.preventDefault();
          applyFocusMode(!root.classList.contains("is-focus-mode"), true, { allowFullscreenRequest: true });
          return;
        }

        handleFocusRailWake();
      });

      let refreshScheduled = false;

      function scheduleSceneRefresh() {
        if (refreshScheduled) {
          return;
        }

        refreshScheduled = true;
        window.requestAnimationFrame(() => {
          refreshScheduled = false;
          updateActiveScene();
        });
      }

      function applyFocusMode(enabled, persist, options = { allowFullscreenRequest: false }) {
        root.classList.toggle("is-focus-mode", enabled);
        window.dispatchEvent(new CustomEvent("narrarium:focus-mode-change", { detail: { enabled } }));
        toggleButtons.forEach((button) => {
          button.textContent = enabled ? "Exit full read" : "Full read";
          button.setAttribute("aria-pressed", enabled ? "true" : "false");
        });
        if (enabled) {
          resetFocusHintSession();
          showFocusRailTemporarily();
        } else {
          clearFocusRailHideTimer();
          clearFocusHintHideTimer();
          focusRail?.classList.remove("is-hidden");
          focusHint?.classList.remove("is-visible");
        }
        scheduleSceneRefresh();

        if (persist) {
          writeStorage(focusModeKey, enabled ? "true" : "false");
        }

        if (options.allowFullscreenRequest) {
          void syncFullscreenForFocusMode(enabled);
        }
      }

      function handleFocusRailWake() {
        if (!root.classList.contains("is-focus-mode")) {
          return;
        }

        hideFocusHint();
        showFocusRailTemporarily();
      }

      function showFocusRailTemporarily() {
        showFocusRail();
        scheduleFocusRailHide();
      }

      function showFocusRail() {
        clearFocusRailHideTimer();
        focusRail?.classList.remove("is-hidden");
      }

      function scheduleFocusRailHide() {
        clearFocusRailHideTimer();

        if (!root.classList.contains("is-focus-mode") || railPointerInside || focusRail?.matches(":focus-within")) {
          return;
        }

        focusRailHideTimer = window.setTimeout(() => {
          if (!railPointerInside && !focusRail?.matches(":focus-within") && root.classList.contains("is-focus-mode")) {
            focusRail?.classList.add("is-hidden");
            showFocusHintOnce();
          }
        }, focusRailHideDelayMs);
      }

      function clearFocusRailHideTimer() {
        if (focusRailHideTimer !== null) {
          window.clearTimeout(focusRailHideTimer);
          focusRailHideTimer = null;
        }
      }

      function showFocusHintOnce() {
        if (focusHintShownForSession || !root.classList.contains("is-focus-mode")) {
          return;
        }

        focusHintShownForSession = true;
        focusHint?.classList.add("is-visible");
        clearFocusHintHideTimer();
        focusHintHideTimer = window.setTimeout(() => {
          focusHint?.classList.remove("is-visible");
          focusHintHideTimer = null;
        }, focusHintHideDelayMs);
      }

      function hideFocusHint() {
        clearFocusHintHideTimer();
        focusHint?.classList.remove("is-visible");
      }

      function resetFocusHintSession() {
        focusHintShownForSession = false;
        hideFocusHint();
      }

      function clearFocusHintHideTimer() {
        if (focusHintHideTimer !== null) {
          window.clearTimeout(focusHintHideTimer);
          focusHintHideTimer = null;
        }
      }

      async function syncFullscreenForFocusMode(enabled) {
        if (typeof fullscreenTarget.requestFullscreen !== "function" || typeof document.exitFullscreen !== "function") {
          return;
        }

        try {
          if (enabled) {
            if (!document.fullscreenElement) {
              await fullscreenTarget.requestFullscreen();
            }
          } else if (document.fullscreenElement) {
            await document.exitFullscreen();
          }
        } catch {
          // Ignore browsers that block or do not support fullscreen transitions.
        }
      }

      function handleFullscreenChange() {
        root.classList.toggle("is-reader-fullscreen", Boolean(document.fullscreenElement));

        if (root.classList.contains("is-focus-mode")) {
          hideFocusHint();
          showFocusRailTemporarily();
        }
      }

      function updateMarkerUi(marker) {
        const activeScopeId = marker?.path === chapterPath ? marker.scopeId : null;

        markerButtons.forEach((button) => {
          const isActive = activeScopeId !== null && button.dataset.readerMarkerScope === activeScopeId;
          button.classList.toggle("is-active", isActive);
          button.textContent = isActive ? "Voice marker set" : "Mark voice start";
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        document.querySelectorAll("[data-reader-marker-article]").forEach((article) => {
          article.classList.toggle("has-voice-marker", activeScopeId !== null && article.dataset.readerMarkerScope === activeScopeId);
        });
      }

      function updateActiveScene() {
        if (sceneElements.length === 0) {
          return;
        }

        const focusLine = Math.max(120, window.innerHeight * 0.32);
        let activeScene = sceneElements[0];

        sceneElements.forEach((scene) => {
          const rect = scene.getBoundingClientRect();
          if (rect.top <= focusLine) {
            activeScene = scene;
          }
        });

        sceneElements.forEach((scene) => {
          scene.classList.toggle("is-current", scene === activeScene);
        });

        const label = activeScene.dataset.readerSceneLabel || "Chapter opening";
        currentSceneLabels.forEach((element) => {
          element.textContent = label;
        });
      }

      function readMarker() {
        try {
          return JSON.parse(localStorage.getItem(voiceMarkerKey) || "null");
        } catch {
          return null;
        }
      }

      function readStorage(key) {
        try {
          return localStorage.getItem(key);
        } catch {
          return null;
        }
      }

      function writeStorage(key, value) {
        try {
          localStorage.setItem(key, value);
        } catch {
          // Ignore storage failures in restricted browsers.
        }
      }

      function isEditable(node) {
        return node instanceof HTMLElement && (node.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(node.tagName));
      }
    })();
  </script>
</BaseLayout>
