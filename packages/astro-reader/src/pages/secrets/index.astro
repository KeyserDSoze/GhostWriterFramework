---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AssetFigure from "../../components/AssetFigure.astro";
import { loadEntityIndexData } from "../../lib/book";
import { buildPublicCanonIndexCards } from "../../lib/public-canon";
import { isFullCanonMode } from "../../lib/reader-mode";

const { ready, entities } = await loadEntityIndexData("secret");
const cards = await buildPublicCanonIndexCards("secret", entities);
const fullMode = isFullCanonMode();
---

<BaseLayout title="Secrets" description="Browse secret dossiers when full canon mode is enabled." activeSection="secrets">
  <section class="hero">
    <p class="eyebrow">Canon Atlas</p>
    <h1>Secrets</h1>
    <p class="lede">Hidden truths stay off the public atlas unless the reader is built in full canon mode.</p>
  </section>

  {ready ? (
    fullMode ? (
      cards.length > 0 ? (
        <section class="section">
          <div class="catalog-grid">
            {cards.map((entity) => (
              <article class="card catalog-card">
                <a href={`secrets/${entity.slug}/`}>
                  {entity.figure && <AssetFigure figure={entity.figure} className="catalog-media" />}
                  <div class="chapter-number">{entity.eyebrow}</div>
                  <h2 class="chapter-title">{entity.label}</h2>
                  <div class="chapter-meta">{entity.summary}</div>
                  {entity.chips.length > 0 && (
                    <div class="chip-row">
                      {entity.chips.map((chip) => <span class="chip">{chip}</span>)}
                    </div>
                  )}
                </a>
              </article>
            ))}
          </div>
        </section>
      ) : (
        <div class="empty">No secrets exist yet.</div>
      )
    ) : (
      <div class="empty">Secrets are intentionally hidden in public reader mode.</div>
    )
  ) : (
    <div class="empty">No book repository detected for the reader.</div>
  )}
</BaseLayout>
