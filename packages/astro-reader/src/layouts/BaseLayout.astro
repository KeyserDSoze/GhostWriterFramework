---
import ReaderRuntime from "../components/ReaderRuntime.astro";
import SiteSearch from "../components/SiteSearch.astro";
import { listChapters } from "narrarium";
import { getBookRoot } from "../lib/book.js";
import { loadCanonGlossary } from "../lib/glossary.js";
import { isFullCanonMode } from "../lib/reader-mode.js";
import { loadSearchIndex } from "../lib/search.js";

interface Props {
  title: string;
  description?: string;
  activeSection?:
    | "home"
    | "chapters"
    | "characters"
    | "locations"
    | "factions"
    | "items"
    | "secrets"
    | "timeline";
  currentChapterNumber?: number;
}

const { title, description, activeSection = "home", currentChapterNumber } = Astro.props;
const canonGlossary = await loadCanonGlossary(currentChapterNumber);
const searchIndex = await loadSearchIndex(currentChapterNumber);
const readerChapters = await listChapters(getBookRoot()).catch(() => []);
const fullCanonMode = isFullCanonMode();
const isChapterPage = Number.isFinite(currentChapterNumber);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <base href={import.meta.env.BASE_URL} />
    <script is:inline>
      (() => {
        const themeStorageKey = "narrarium-reader-theme";
        const root = document.documentElement;
        const prefersDark =
          typeof window.matchMedia === "function" && window.matchMedia("(prefers-color-scheme: dark)").matches;

        try {
          const saved = localStorage.getItem(themeStorageKey);
          root.dataset.theme = saved || (prefersDark ? "dark" : "light");
        } catch {
          root.dataset.theme = prefersDark ? "dark" : "light";
        }
      })();
    </script>
    <style>
      :root {
        --app-bg: #ffffff;
        --surface: #ffffff;
        --surface-muted: #f6f7f9;
        --surface-strong: #f1f3f6;
        --text: #111111;
        --text-muted: #5f6368;
        --line: #e3e7ee;
        --accent: #2563eb;
        --accent-soft: #dbeafe;
        --shadow: 0 10px 24px rgba(17, 24, 39, 0.06);
        --ui-family: "Avenir Next", "Segoe UI", sans-serif;
        --copy-family: Charter, "Iowan Old Style", Georgia, serif;
        --reader-font-scale: 1;
        --reader-leading: 1.72;
        --reader-measure: 68ch;
        --reader-copy-family: Charter, "Iowan Old Style", Georgia, serif;
      }

      html[data-theme="dark"] {
        --app-bg: #000000;
        --surface: #0f0f10;
        --surface-muted: #151618;
        --surface-strong: #1d1f22;
        --text: #f5f7fa;
        --text-muted: #a8adb5;
        --line: #2a2d33;
        --accent: #8ab4f8;
        --accent-soft: rgba(138, 180, 248, 0.12);
        --shadow: 0 12px 28px rgba(0, 0, 0, 0.3);
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--app-bg);
        color: var(--text);
        font-family: var(--ui-family);
        line-height: 1.55;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--app-bg);
        color: var(--text);
      }

      body.tts-enabled .shell {
        padding-bottom: 8rem;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1120px, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 1rem 0 3rem;
      }

      .masthead {
        position: sticky;
        top: 0;
        z-index: 20;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 0;
        margin-bottom: 2rem;
        background: color-mix(in srgb, var(--app-bg) 88%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--line);
      }

      .brand {
        color: var(--text);
        font-size: 0.92rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
        white-space: nowrap;
      }

      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
      }

      .nav-link {
        padding: 0.35rem 0;
        border-bottom: 2px solid transparent;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.92rem;
      }

      .nav-link.is-active {
        color: var(--text);
        border-bottom-color: var(--accent);
      }

      .masthead-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .site-search {
        position: relative;
        min-width: min(320px, 80vw);
      }

      .site-search__field {
        display: grid;
        gap: 0.3rem;
      }

      .site-search__field input,
      .pager-jump select,
      .reader-control input,
      .reader-control select,
      .tts-player__settings select,
      .tts-player__settings input {
        width: 100%;
        padding: 0.78rem 0.9rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--surface);
        color: var(--text);
        font: inherit;
      }

      .site-search__results,
      .canon-overlay__panel,
      .reader-overlay__panel,
      .tts-player,
      .focus-rail {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 12px;
        box-shadow: var(--shadow);
      }

      .site-search__results {
        position: absolute;
        top: calc(100% + 0.4rem);
        left: 0;
        right: 0;
        padding: 0.4rem;
        z-index: 25;
      }

      .site-search__filters {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: 0.45rem;
      }

      .site-search__filter,
      .theme-toggle,
      .chip,
      .tts-button,
      .focus-rail__button,
      .focus-rail__link,
      .canon-tab {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.5rem;
        padding: 0.55rem 0.85rem;
        border: 1px solid var(--line);
        border-radius: 10px;
        background: var(--surface);
        color: var(--text);
        font: inherit;
        text-decoration: none;
        cursor: pointer;
        transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
      }

      .site-search__filter,
      .chip,
      .canon-tab {
        min-height: 2rem;
        padding: 0.35rem 0.65rem;
        font-size: 0.88rem;
      }

      .site-search__filter.is-active,
      .chip.is-action.is-active,
      .scene-marker.is-active,
      .focus-rail__button.is-primary,
      .canon-tab.is-active {
        background: var(--accent-soft);
        border-color: color-mix(in srgb, var(--accent) 25%, var(--line));
      }

      .site-search__result {
        display: grid;
        gap: 0.35rem;
        padding: 0.75rem;
        text-decoration: none;
      }

      .site-search__result:hover,
      .site-search__filter:hover,
      .theme-toggle:hover,
      .chip.is-action:hover,
      .tts-button:hover,
      .focus-rail__button:hover,
      .focus-rail__link:hover,
      .canon-tab:hover,
      .pager-link:hover {
        background: var(--surface-muted);
      }

      .hero {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--line);
        max-width: 76ch;
      }

      .page-chapter .hero,
      .page-chapter .chapter-pager,
      .page-chapter .chapter-reading-frame,
      .page-chapter .section > .card,
      .page-chapter .section > .empty,
      .page-chapter .section > .scene {
        max-width: min(100%, calc(var(--reader-measure) + 8ch));
        margin-inline: auto;
      }

      .eyebrow,
      .label,
      .chapter-number,
      .meta-key {
        color: var(--text-muted);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        color: var(--text);
        line-height: 1.15;
      }

      h1 {
        font-size: clamp(2rem, 4vw, 3.3rem);
      }

      h2 {
        font-size: clamp(1.3rem, 2.4vw, 1.9rem);
      }

      h3 {
        font-size: 1.1rem;
      }

      .lede,
      .chapter-meta,
      .meta-value,
      .tts-player__label,
      .tts-status,
      .focus-rail__status {
        color: var(--text-muted);
      }

      .lede {
        max-width: 64ch;
        margin: 0.9rem 0 0;
        font-size: 1.02rem;
        line-height: 1.65;
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .stats,
      .catalog-grid {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      }

      .card,
      .chapter-card,
      .chapter-reading-frame,
      .chapter-focus-banner,
      .empty {
        background: var(--surface);
        border: 1px solid var(--line);
      }

      .card,
      .chapter-card,
      .chapter-reading-frame,
      .chapter-focus-banner,
      .empty,
      .chapter-pager {
        border-radius: 12px;
      }

      .card,
      .catalog-card,
      .chapter-card,
      .chapter-reading-frame,
      .chapter-focus-banner,
      .chapter-pager,
      .empty {
        padding: 1rem;
      }

      .value {
        margin-top: 0.3rem;
        font-size: 1rem;
      }

      .value-path {
        overflow-wrap: anywhere;
        word-break: break-word;
        font-family: Consolas, "SFMono-Regular", monospace;
        font-size: 0.92rem;
      }

      .section {
        margin-top: 2rem;
      }

      .chapter-list,
      .scene-stack {
        display: grid;
        gap: 1rem;
      }

      .page-chapter .scene-stack {
        gap: 0;
      }

      .chapter-card a,
      .catalog-card a {
        display: grid;
        gap: 0.55rem;
        text-decoration: none;
      }

      .chapter-card,
      .catalog-card {
        transition: border-color 140ms ease, background 140ms ease;
      }

      .chapter-card:hover,
      .catalog-card:hover {
        background: var(--surface-muted);
        border-color: color-mix(in srgb, var(--accent) 18%, var(--line));
      }

      .chapter-card .chapter-meta,
      .catalog-card .chapter-meta {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .chapter-back-link {
        display: inline-flex;
        margin-bottom: 0.9rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.92rem;
      }

      .chapter-actions {
        margin-top: 1rem;
      }

      .scene {
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--line);
      }

      .scene:last-child {
        border-bottom: 0;
      }

      .scene-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
      }

      .scene-header > div:first-child {
        display: grid;
        gap: 0.3rem;
      }

      .chapter-outline {
        display: grid;
        gap: 0.8rem;
      }

      .chapter-outline__header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
      }

      .chapter-outline__list {
        display: grid;
      }

      .chapter-outline__item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.75rem;
        padding: 0.85rem 0;
        border-top: 1px solid var(--line);
        text-decoration: none;
      }

      .chapter-outline__item:first-child {
        border-top: 0;
        padding-top: 0;
      }

      .chapter-outline__index {
        color: var(--text-muted);
        font-size: 0.84rem;
        font-weight: 600;
        letter-spacing: 0.06em;
      }

      .chapter-outline__item-title {
        display: block;
        font-weight: 600;
      }

      .chapter-outline__item-summary {
        display: block;
        margin-top: 0.2rem;
        color: var(--text-muted);
        font-size: 0.94rem;
      }

      .scene-tools,
      .chip-row,
      .tts-player__controls,
      .tts-player__settings,
      .focus-rail__controls,
      .canon-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
      }

      .prose {
        max-width: min(100%, var(--reader-measure));
        color: var(--text);
        font-family: var(--reader-copy-family);
        font-size: calc(1.03rem * var(--reader-font-scale));
        line-height: var(--reader-leading);
      }

      .prose :global(p:first-child) {
        margin-top: 0;
      }

      .prose :global(p),
      .prose :global(ul),
      .prose :global(ol),
      .prose :global(blockquote) {
        margin: 0 0 1rem;
      }

      .prose :global(h1),
      .prose :global(h2),
      .prose :global(h3) {
        margin: 1.4rem 0 0.8rem;
      }

      .scene a,
      .meta-value a,
      .canon-mention {
        color: var(--accent);
        text-decoration-color: color-mix(in srgb, var(--accent) 50%, transparent);
        text-underline-offset: 0.15em;
      }

      .chapter-pager {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        gap: 0.8rem;
        align-items: center;
        border: 1px solid var(--line);
        background: var(--surface);
      }

      .pager-link.is-disabled,
      .focus-rail__link.is-disabled,
      .focus-rail__button:disabled {
        opacity: 0.45;
        pointer-events: none;
      }

      .pager-jump {
        display: grid;
        gap: 0.35rem;
      }

      .media-frame {
        margin: 1rem 0 0;
      }

      .media-frame img,
      .canon-overlay__image-panel img {
        display: block;
        width: 100%;
        height: auto;
        border: 1px solid var(--line);
      }

      .hero-media,
      .scene-media,
      .catalog-media {
        max-width: min(420px, 100%);
      }

      .meta-list {
        display: grid;
        gap: 0.75rem;
      }

      .meta-row {
        display: grid;
        grid-template-columns: minmax(120px, 180px) 1fr;
        gap: 0.75rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--line);
      }

      .meta-row:last-child {
        border-bottom: 0;
        padding-bottom: 0;
      }

      .empty {
        color: var(--text-muted);
      }

      .canon-overlay,
      .reader-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
      }

      .canon-overlay__backdrop,
      .reader-overlay__backdrop {
        position: absolute;
        inset: 0;
        border: 0;
        background: rgba(0, 0, 0, 0.5);
      }

      .canon-overlay__panel,
      .reader-overlay__panel {
        position: relative;
        width: min(640px, calc(100vw - 1.5rem));
        max-height: calc(100vh - 2rem);
        overflow: auto;
        margin: 1rem auto;
        padding: 1rem;
      }

      .canon-overlay__close,
      .reader-overlay__close {
        position: sticky;
        top: 0;
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--surface-muted);
        color: var(--text);
        cursor: pointer;
      }

      .canon-panel {
        display: none;
      }

      .canon-panel.is-active {
        display: block;
      }

      body.has-overlay {
        overflow: hidden;
      }

      .reader-control-grid {
        display: grid;
        gap: 0.9rem;
      }

      .reader-control {
        display: grid;
        gap: 0.35rem;
      }

      .reader-control input[type="range"],
      .tts-player__settings input[type="range"] {
        padding-inline: 0;
      }

      .tts-player {
        position: fixed;
        right: 1rem;
        bottom: 1rem;
        z-index: 45;
        width: min(440px, calc(100vw - 1rem));
        padding: 1rem;
      }

      .tts-player__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
      }

      .tts-player__title {
        margin: 0.2rem 0 0;
        font-weight: 600;
      }

      .tts-segment {
        transition: background 140ms ease, color 140ms ease;
      }

      .tts-segment.is-speaking {
        background: var(--accent-soft);
      }

      .scene.is-speaking,
      .scene.has-voice-marker,
      .scene.is-current {
        border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
      }

      .chapter-reading-frame {
        padding: 1.2rem;
      }

      .chapter-focus-banner {
        display: none;
        margin: 0 0 1rem;
      }

      .focus-rail {
        display: none;
        position: fixed;
        left: 50%;
        bottom: 1rem;
        transform: translateX(-50%);
        z-index: 46;
        width: min(760px, calc(100vw - 1rem));
        padding: 0.9rem 1rem;
      }

      .focus-rail__meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.8rem;
      }

      .focus-rail__title {
        font-weight: 600;
      }

      body.is-focus-mode {
        background: var(--app-bg);
      }

      body.is-focus-mode .masthead,
      body.is-focus-mode .focus-hidden,
      body.is-focus-mode .reader-overlay,
      body.is-focus-mode .canon-overlay,
      body.is-focus-mode .tts-player,
      body.is-focus-mode .scene-tools,
      body.is-focus-mode .scene-media {
        display: none !important;
      }

      body.is-focus-mode .shell {
        width: min(860px, calc(100vw - 2rem));
        padding-top: 1rem;
        padding-bottom: 7.5rem;
      }

      body.is-focus-mode .chapter-reading-frame {
        padding: 0;
        border: 0;
      }

      body.is-focus-mode .chapter-focus-banner {
        display: block;
        border: 0;
        border-bottom: 1px solid var(--line);
        border-radius: 0;
        padding: 0 0 1rem;
        margin-inline: auto;
        max-width: min(100%, calc(var(--reader-measure) + 8ch));
      }

      body.is-focus-mode .scene {
        max-width: min(100%, calc(var(--reader-measure) + 8ch));
        margin-inline: auto;
        padding: 1.4rem 0;
      }

      body.is-focus-mode .scene.is-current {
        border-color: var(--accent);
      }

      body.is-focus-mode .focus-rail {
        display: block;
      }

      mark {
        background: var(--accent-soft);
        color: inherit;
      }

      @media (max-width: 900px) {
        .masthead {
          grid-template-columns: 1fr;
          align-items: stretch;
        }

        .site-nav,
        .masthead-actions {
          justify-content: flex-start;
        }

        .site-nav {
          overflow-x: auto;
          white-space: nowrap;
          padding-bottom: 0.2rem;
        }
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 1rem, 1120px);
        }

        .stats,
        .catalog-grid,
        .chapter-pager,
        .meta-row,
        .scene-header,
        .chapter-outline__header,
        .focus-rail__meta,
        .focus-rail__controls {
          grid-template-columns: 1fr;
          flex-direction: column;
          align-items: stretch;
        }

        .site-search {
          min-width: 0;
        }

        .theme-toggle,
        .focus-rail__button,
        .focus-rail__link {
          width: 100%;
        }

        .tts-player,
        .focus-rail {
          left: 0.5rem;
          right: 0.5rem;
          width: auto;
          transform: none;
        }

        body.is-focus-mode .shell {
          width: min(100vw - 1rem, 860px);
          padding-bottom: 13rem;
        }
      }
    </style>
  </head>
  <body class:list={[isChapterPage && "page-chapter"]} data-reader-chapter-number={currentChapterNumber}>
    <main class="shell">
      <header class="masthead">
        <a class="brand" href="./">Narrarium Reader</a>
        <nav class="site-nav">
          <a class:list={["nav-link", activeSection === "home" && "is-active"]} href="./">Book</a>
          <a class:list={["nav-link", activeSection === "chapters" && "is-active"]} href="./#chapters">Chapters</a>
          <a class:list={["nav-link", activeSection === "characters" && "is-active"]} href="characters/">Characters</a>
          <a class:list={["nav-link", activeSection === "locations" && "is-active"]} href="locations/">Locations</a>
          <a class:list={["nav-link", activeSection === "factions" && "is-active"]} href="factions/">Factions</a>
          <a class:list={["nav-link", activeSection === "items" && "is-active"]} href="items/">Items</a>
          {fullCanonMode && <a class:list={["nav-link", activeSection === "secrets" && "is-active"]} href="secrets/">Secrets</a>}
          <a class:list={["nav-link", activeSection === "timeline" && "is-active"]} href="timeline/">Timeline</a>
        </nav>
        <div class="masthead-actions">
          <SiteSearch entries={searchIndex} />
          <a class="chip reader-status" data-continue-link href="./" hidden>Continue reading</a>
          <button type="button" class="theme-toggle" data-reader-settings-toggle aria-label="Open reading settings">Reading</button>
          <button type="button" class="theme-toggle" data-theme-toggle aria-label="Switch theme">Dark mode</button>
        </div>
      </header>
      <slot />
    </main>
    <ReaderRuntime glossary={canonGlossary} chapters={readerChapters} currentChapterNumber={currentChapterNumber} />
  </body>
</html>
