---
import "../styles/global.css";
import ReaderRuntime from "../components/ReaderRuntime.astro";
import SiteSearch from "../components/SiteSearch.astro";
import { listChapters } from "narrarium";
import { getBookRoot } from "../lib/book.js";
import { loadCanonGlossary } from "../lib/glossary.js";
import { isFullCanonMode, getReaderPasswordHash } from "../lib/reader-mode.js";
import { loadSearchIndex } from "../lib/search.js";

interface Props {
  title: string;
  description?: string;
  activeSection?:
    | "home"
    | "chapters"
    | "workshop"
    | "characters"
    | "locations"
    | "factions"
    | "items"
    | "secrets"
    | "timeline";
  currentChapterNumber?: number;
}

const { title, description, activeSection = "home", currentChapterNumber } = Astro.props;
const canonGlossary = await loadCanonGlossary(currentChapterNumber);
const searchIndex = await loadSearchIndex(currentChapterNumber);
const readerChapters = await listChapters(getBookRoot()).catch(() => []);
const fullCanonMode = isFullCanonMode();
const passwordHash = getReaderPasswordHash();
const isChapterPage = Number.isFinite(currentChapterNumber);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <base href={import.meta.env.BASE_URL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      (() => {
        const themeStorageKey = "narrarium-reader-theme";
        const root = document.documentElement;
        const prefersDark =
          typeof window.matchMedia === "function" && window.matchMedia("(prefers-color-scheme: dark)").matches;

        try {
          const saved = localStorage.getItem(themeStorageKey);
          root.dataset.theme = saved || (prefersDark ? "dark" : "light");
        } catch {
          root.dataset.theme = prefersDark ? "dark" : "light";
        }
      })();
    </script>
  </head>
  <body class:list={[isChapterPage && "page-chapter"]} data-reader-chapter-number={currentChapterNumber} data-full-canon={fullCanonMode ? "true" : "false"} data-reader-password-hash={passwordHash ?? ""}>
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("narrarium-reader-canon");
          if (saved !== null) {
            document.body.dataset.fullCanon = saved === "full" ? "true" : "false";
          }
        } catch {}
      })();
    </script>
    <script is:inline>
      (() => {
        const hash = document.body.dataset.readerPasswordHash;
        if (!hash) return;
        try {
          if (localStorage.getItem("narrarium-reader-auth") !== hash) {
            document.body.classList.add("reader-auth-locked");
          }
        } catch {
          document.body.classList.add("reader-auth-locked");
        }
      })();
    </script>
    {passwordHash && (
      <div id="reader-password-gate" role="dialog" aria-modal="true" aria-label="Access required">
        <div class="reader-password-gate__inner">
          <p class="eyebrow">Narrarium Reader</p>
          <h1 class="reader-password-gate__title">Access Required</h1>
          <p class="reader-password-gate__desc">Enter the password to access this book.</p>
          <form id="reader-password-form" class="reader-password-gate__form" novalidate>
            <input
              type="password"
              id="reader-password-input"
              class="reader-password-gate__input"
              placeholder="Password"
              autocomplete="current-password"
            />
            <button type="submit" class="reader-password-gate__button">Unlock</button>
          </form>
          <p id="reader-password-error" class="reader-password-gate__error" hidden>Incorrect password. Please try again.</p>
        </div>
      </div>
    )}
    <main class="shell">
      <header class="masthead">
        <a class="brand" href="./">Narrarium</a>
        <nav class="site-nav">
          <a class:list={["nav-link", activeSection === "home" && "is-active"]} href="./">Book</a>
          <a class:list={["nav-link", activeSection === "chapters" && "is-active"]} href="./#chapters">Chapters</a>
          {fullCanonMode && <a class:list={["nav-link", activeSection === "workshop" && "is-active"]} href="workshop/">Workshop</a>}
          <a class:list={["nav-link", activeSection === "characters" && "is-active"]} href="characters/">Characters</a>
          <a class:list={["nav-link", activeSection === "locations" && "is-active"]} href="locations/">Locations</a>
          <a class:list={["nav-link", activeSection === "factions" && "is-active"]} href="factions/">Factions</a>
          <a class:list={["nav-link", activeSection === "items" && "is-active"]} href="items/">Items</a>
          {fullCanonMode && <a class:list={["nav-link", activeSection === "secrets" && "is-active"]} href="secrets/">Secrets</a>}
          <a class:list={["nav-link", activeSection === "timeline" && "is-active"]} href="timeline/">Timeline</a>
        </nav>
        <div class="masthead-actions">
          <a class="chip reader-status" data-continue-link href="./" hidden>Continue reading</a>
          <button type="button" class="masthead-btn" data-tts-panel-toggle aria-label="Open read aloud controls" aria-pressed="false" hidden>🔊</button>
          <button type="button" class="masthead-btn" data-search-toggle aria-label="Search">🔍</button>
          <button type="button" class="masthead-btn" data-reader-settings-toggle aria-label="Open reading settings">⚙</button>
        </div>
      </header>
      <slot />
    </main>
    <SiteSearch entries={searchIndex} />
    <ReaderRuntime glossary={canonGlossary} chapters={readerChapters} currentChapterNumber={currentChapterNumber} />
    {passwordHash && (
      <script is:inline>
        (function initPasswordGate() {
          var gate = document.getElementById("reader-password-gate");
          var form = document.getElementById("reader-password-form");
          var input = document.getElementById("reader-password-input");
          var errorEl = document.getElementById("reader-password-error");
          var hash = document.body.dataset.readerPasswordHash;
          if (!gate || !form || !hash) return;
          if (input) { input.focus(); }
          function buf2hex(buffer) {
            return Array.from(new Uint8Array(buffer))
              .map(function (b) { return b.toString(16).padStart(2, "0"); })
              .join("");
          }
          form.addEventListener("submit", function (event) {
            event.preventDefault();
            var password = input ? input.value : "";
            if (!password) return;
            var data = new TextEncoder().encode(password);
            crypto.subtle.digest("SHA-256", data).then(function (hashBuffer) {
              var inputHash = buf2hex(hashBuffer);
              if (inputHash === hash) {
                try { localStorage.setItem("narrarium-reader-auth", hash); } catch {}
                document.body.classList.remove("reader-auth-locked");
              } else {
                if (errorEl) { errorEl.hidden = false; }
                if (input) { input.value = ""; input.focus(); }
              }
            }).catch(function () {
              if (errorEl) { errorEl.hidden = false; }
            });
          });
        })();
      </script>
    )}
  </body>
</html>
