---
interface Props {
  title: string;
  description?: string;
  activeSection?:
    | "home"
    | "chapters"
    | "characters"
    | "locations"
    | "factions"
    | "items"
    | "secrets"
    | "timeline";
}

const { title, description, activeSection = "home" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <style>
      :root {
        --paper: #f3ecdd;
        --paper-deep: #eadfcb;
        --ink: #2c2018;
        --muted: #705742;
        --accent: #975f2d;
        --line: rgba(44, 32, 24, 0.12);
        --panel: rgba(255, 250, 240, 0.72);
        --shadow: 0 24px 60px rgba(44, 32, 24, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      html {
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.55), transparent 35%),
          repeating-linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.12) 0,
            rgba(255, 255, 255, 0.12) 2px,
            transparent 2px,
            transparent 6px
          ),
          linear-gradient(180deg, var(--paper), var(--paper-deep));
        color: var(--ink);
        font-family: Baskerville, "Palatino Linotype", "Book Antiqua", "Iowan Old Style", serif;
        line-height: 1.65;
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1080px, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }

      .masthead {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.25rem;
        padding: 0.9rem 1rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 251, 243, 0.78);
        backdrop-filter: blur(8px);
        box-shadow: var(--shadow);
      }

      .brand {
        font-size: 0.92rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
      }

      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .nav-link {
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--muted);
        border: 1px solid transparent;
      }

      .nav-link.is-active {
        color: var(--ink);
        background: rgba(151, 95, 45, 0.12);
        border-color: rgba(151, 95, 45, 0.18);
      }

      .hero {
        padding: 3rem clamp(1.2rem, 2vw, 2rem);
        border: 1px solid var(--line);
        border-radius: 28px;
        background: linear-gradient(135deg, rgba(255, 251, 243, 0.92), rgba(244, 233, 213, 0.8));
        box-shadow: var(--shadow);
      }

      .eyebrow {
        margin: 0 0 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.78rem;
        color: var(--muted);
      }

      h1,
      h2,
      h3 {
        font-weight: 600;
        line-height: 1.1;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.4rem, 5vw, 4.8rem);
      }

      h2 {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        margin-top: 0;
      }

      .lede {
        max-width: 62ch;
        font-size: 1.06rem;
        color: var(--muted);
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .stats {
        margin-top: 1.5rem;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }

      .card,
      .chapter-card,
      .scene {
        border: 1px solid var(--line);
        border-radius: 22px;
        background: var(--panel);
        backdrop-filter: blur(8px);
        box-shadow: var(--shadow);
      }

      .card {
        padding: 1rem 1.1rem;
      }

      .label {
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      .value {
        margin-top: 0.35rem;
        font-size: 1.15rem;
      }

      .chapter-list {
        margin-top: 2rem;
        display: grid;
        gap: 1rem;
      }

      .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
      }

      .catalog-card {
        padding: 1.2rem 1.25rem;
      }

      .catalog-card a {
        text-decoration: none;
      }

      .scene a,
      .meta-value a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.12em;
      }

      .chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0.9rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        padding: 0.24rem 0.55rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        font-size: 0.82rem;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.38);
        text-decoration: none;
      }

      .chapter-card {
        padding: 1.15rem 1.2rem;
        transition: transform 140ms ease, box-shadow 140ms ease;
      }

      .chapter-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 30px 70px rgba(44, 32, 24, 0.16);
      }

      .chapter-card a {
        text-decoration: none;
      }

      .media-frame {
        margin: 1.25rem 0 0;
      }

      .media-frame img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 24px;
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        object-fit: cover;
        background: rgba(255, 255, 255, 0.45);
      }

      .hero-media {
        max-width: min(360px, 100%);
      }

      .scene-media {
        max-width: min(420px, 100%);
      }

      .chapter-meta {
        color: var(--muted);
        font-size: 0.95rem;
      }

      .chapter-number {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
      }

      .chapter-title {
        font-size: 1.55rem;
        margin: 0.4rem 0 0.5rem;
      }

      .section {
        margin-top: 2rem;
      }

      .scene {
        padding: 1.35rem 1.4rem;
        margin-top: 1rem;
      }

      .scene h3 {
        margin: 0 0 0.5rem;
      }

      .prose :global(p:first-child) {
        margin-top: 0;
      }

      .meta-list {
        display: grid;
        gap: 0.65rem;
      }

      .meta-row {
        display: grid;
        grid-template-columns: minmax(120px, 180px) 1fr;
        gap: 0.75rem;
        padding-bottom: 0.65rem;
        border-bottom: 1px solid var(--line);
      }

      .meta-key {
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.78rem;
      }

      .meta-value {
        min-width: 0;
      }

      .empty {
        margin-top: 2rem;
        padding: 1.2rem 1.3rem;
        border-radius: 22px;
        border: 1px dashed var(--line);
        background: rgba(255, 255, 255, 0.34);
        color: var(--muted);
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 1rem, 1080px);
          padding-top: 1rem;
        }

        .hero,
        .scene,
        .chapter-card,
        .card {
          border-radius: 18px;
        }

        .masthead {
          border-radius: 24px;
          align-items: flex-start;
          flex-direction: column;
        }

        .meta-row {
          grid-template-columns: 1fr;
          gap: 0.3rem;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <a class="brand" href="/">GhostWriter Reader</a>
        <nav class="site-nav">
          <a class:list={["nav-link", activeSection === "home" && "is-active"]} href="/">Book</a>
          <a class:list={["nav-link", activeSection === "chapters" && "is-active"]} href="/#chapters">Chapters</a>
          <a class:list={["nav-link", activeSection === "characters" && "is-active"]} href="/characters/">Characters</a>
          <a class:list={["nav-link", activeSection === "locations" && "is-active"]} href="/locations/">Locations</a>
          <a class:list={["nav-link", activeSection === "factions" && "is-active"]} href="/factions/">Factions</a>
          <a class:list={["nav-link", activeSection === "items" && "is-active"]} href="/items/">Items</a>
          <a class:list={["nav-link", activeSection === "secrets" && "is-active"]} href="/secrets/">Secrets</a>
          <a class:list={["nav-link", activeSection === "timeline" && "is-active"]} href="/timeline/">Timeline</a>
        </nav>
      </header>
      <slot />
    </main>
  </body>
</html>
