---
import { getDocGroups } from "../lib/docs";
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
  activeHref?: string;
}

const { title, description = "Narrarium documentation", activeHref = "/" } = Astro.props;
const groups = await getDocGroups();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Narrarium Docs</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #f2ede3;
        --panel: rgba(255, 252, 247, 0.88);
        --text: #1f1f1a;
        --muted: #5f665e;
        --line: rgba(40, 54, 46, 0.12);
        --accent: #0f6c63;
        --accent-soft: rgba(15, 108, 99, 0.1);
        --shadow: 0 18px 40px rgba(50, 44, 31, 0.08);
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(15, 108, 99, 0.14), transparent 34%),
          radial-gradient(circle at right 15%, rgba(176, 118, 55, 0.12), transparent 24%),
          var(--bg);
      }

      a { color: inherit; }

      .shell {
        width: min(1400px, calc(100% - 2rem));
        margin: 0 auto;
        display: grid;
        grid-template-columns: 290px minmax(0, 1fr);
        gap: 1.25rem;
        padding: 1rem 0 2rem;
      }

      .sidebar,
      .content {
        background: var(--panel);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        border-radius: 28px;
        backdrop-filter: blur(10px);
      }

      .sidebar {
        position: sticky;
        top: 1rem;
        align-self: start;
        padding: 1.25rem;
      }

      .brand {
        display: block;
        text-decoration: none;
        margin-bottom: 1rem;
      }

      .eyebrow {
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        color: var(--accent);
      }

      .brand h1 {
        margin: 0.35rem 0 0;
        font-size: 1.55rem;
      }

      .brand p,
      .nav-group p,
      .meta {
        color: var(--muted);
      }

      .nav-group {
        margin-top: 1.2rem;
      }

      .nav-group h2 {
        margin: 0 0 0.55rem;
        font-size: 0.84rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .nav-list {
        display: grid;
        gap: 0.35rem;
      }

      .nav-link {
        display: block;
        padding: 0.6rem 0.75rem;
        border-radius: 14px;
        text-decoration: none;
        color: var(--muted);
      }

      .nav-link:hover,
      .nav-link.active {
        color: var(--text);
        background: var(--accent-soft);
      }

      .content {
        padding: 1.5rem clamp(1rem, 3vw, 2.4rem);
      }

      .content :global(h1),
      .content :global(h2),
      .content :global(h3) {
        line-height: 1.15;
      }

      .content :global(.hero) {
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--line);
        margin-bottom: 1.35rem;
      }

      .content :global(.lede) {
        font-size: 1.08rem;
        color: var(--muted);
        max-width: 65ch;
      }

      .content :global(.grid) {
        display: grid;
        gap: 1rem;
      }

      .content :global(.cards) {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .content :global(.card) {
        padding: 1rem;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.56);
      }

      .content :global(.card h3) {
        margin-top: 0;
      }

      .content :global(.pill) {
        display: inline-flex;
        align-items: center;
        padding: 0.3rem 0.55rem;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.82rem;
        text-decoration: none;
      }

      .content :global(.doc-prose) {
        max-width: 78ch;
      }

      .content :global(.doc-prose pre) {
        overflow-x: auto;
        padding: 1rem;
        border-radius: 18px;
        background: #1d2a28;
        color: #eaf2ef;
      }

      .content :global(.doc-prose code) {
        font-family: Consolas, "Courier New", monospace;
        font-size: 0.92em;
      }

      .content :global(.doc-prose :not(pre) > code) {
        padding: 0.12rem 0.3rem;
        border-radius: 6px;
        background: rgba(15, 108, 99, 0.08);
      }

      .content :global(.doc-prose a) {
        color: var(--accent);
      }

      .content :global(table) {
        width: 100%;
        border-collapse: collapse;
      }

      .content :global(th),
      .content :global(td) {
        padding: 0.75rem;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }

      .content :global(.source-note) {
        margin-top: 1rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      @media (max-width: 980px) {
        .shell {
          grid-template-columns: 1fr;
        }

        .sidebar {
          position: static;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <a class="brand" href={withBase("/")}>
          <p class="eyebrow">Narrarium</p>
          <h1>Documentation</h1>
          <p>GitHub Pages reference site generated from the repository itself.</p>
        </a>

        <div class="nav-group">
          <h2>Start</h2>
          <div class="nav-list">
            <a class:list={["nav-link", activeHref === "/" && "active"]} href={withBase("/")}>Home</a>
            <a class:list={["nav-link", activeHref === "/docs/" && "active"]} href={withBase("/docs/")}>All Docs</a>
            <a class:list={["nav-link", activeHref === "/mcp/" && "active"]} href={withBase("/mcp/")}>MCP Integration</a>
          </div>
        </div>

        {groups.map((group) => (
          <div class="nav-group">
            <h2>{group.label}</h2>
            <div class="nav-list">
              {group.docs.map((doc) => (
                <a class:list={["nav-link", activeHref === doc.href && "active"]} href={withBase(doc.href)}>{doc.title}</a>
              ))}
            </div>
          </div>
        ))}
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
