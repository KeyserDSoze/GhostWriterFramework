# Google OAuth client ID (required)
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized JavaScript origins: https://narrarium.net, http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Override the base path for the BMS (default: /bms/ in production, / in dev)
# BMS_BASE=/bms/
